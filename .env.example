# .env — Copy this file, rename it to .env, and fill in your real values.
# NEVER commit your real .env to GitHub. It contains secret keys.

# ── AI Provider ──────────────────────────────────────────────────────────────
# Get this from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
OPENROUTER_MAX_TOKENS=1024

# ── Affiliate Programs ──────────────────────────────────────────────────────
# Amazon Associates: https://affiliate-program.amazon.com
# Format: yourname-20 (the -20 is required for US)
AMAZON_AFFILIATE_TAG=your-tag-20

# eBay Partner Network: https://partnernetwork.ebay.com
# Leave blank if not yet registered
EBAY_CAMPAIGN_ID=

# Walmart Affiliates (via Impact): https://affiliates.walmart.com
# Leave blank if not yet registered
WALMART_IMPACT_ID=

# Geniuslink: https://geniuslink.com ($5/mo — localizes links globally)
# Leave blank to use direct links instead
GENIUSLINK_TSID=

# ── Server ───────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["*"]
RATE_LIMIT_PER_MINUTE=10
