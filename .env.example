# .env — Copy this file, rename it to .env, and fill in your real values.
# NEVER commit your real .env to GitHub. It contains secret keys.

# Get this from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Model to use via OpenRouter (free-tier model)
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

# Max tokens per response (1024 is plenty for product recs)
OPENROUTER_MAX_TOKENS=1024

# Get this after joining Amazon Associates: https://affiliate-program.amazon.com
# Format: yourname-20  (the -20 is required for US Associates)
AMAZON_AFFILIATE_TAG=your-tag-20

# Comma-separated list of allowed frontend origins (CORS)
# For local dev, leave as *
# For production, set to your actual domain: https://fixr.yoursite.com
ALLOWED_ORIGINS=["*"]

# Max chat requests per IP per minute (prevents abuse / runaway API costs)
RATE_LIMIT_PER_MINUTE=10
